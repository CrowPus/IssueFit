# =====================================================================
# Production settings. Copy this file to ".env" on your VM and fill in
# every value marked CHANGE_ME. Do NOT commit the real .env.
# =====================================================================

# Your website address. DNS for this must point at your VM's IP.
DOMAIN=issuefit.example.com

# --- Database (runs inside Docker) ---
POSTGRES_USER=issuefit
POSTGRES_PASSWORD=CHANGE_ME_use_a_long_random_password
POSTGRES_DB=issuefit

# The app reaches the database THROUGH PgBouncer. Keep host=pgbouncer and
# port=6432. The password below MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgres://issuefit:CHANGE_ME_use_a_long_random_password@pgbouncer:6432/issuefit

# --- Sign-in / sessions ---
# Generate the secret with:  openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32
# Must be https:// + your DOMAIN.
BETTER_AUTH_URL=https://issuefit.example.com

# --- GitHub sign-in (OAuth app) ---
# Create at github.com/settings/developers -> New OAuth App.
# Authorization callback URL must be:
#   https://issuefit.example.com/api/auth/callback/github
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME

# --- Read-only token to fetch public repos for the catalog ---
# github.com/settings/tokens -> fine-grained -> Public repositories, read-only.
GITHUB_SERVICE_TOKEN=CHANGE_ME

# --- Admin ---
# Comma-separated GitHub usernames allowed into /admin. Put YOUR username.
ADMIN_GITHUB_USERNAMES=CrowPus

# --- Worker / email (safe defaults; leave as-is for launch) ---
WEEKLY_DIGEST_ENABLED=false
EMAIL_DELIVERY_MODE=log
LOG_LEVEL=info
